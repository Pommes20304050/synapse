# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic API key — OR enter it later via the Settings page in the UI
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Change this to a long random string in production
SECRET_KEY=change-me-in-production

# ── Optional: GitHub OAuth ───────────────────────────────────────────────────
# 1. Go to github.com/settings/developers → New OAuth App
# 2. Set Homepage URL:               http://localhost:3000
# 3. Set Authorization callback URL: http://localhost:5173/auth/callback
# 4. Copy the values below:
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional: Google OAuth ────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI: http://localhost:5173/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
